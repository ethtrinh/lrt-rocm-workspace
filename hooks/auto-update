#!/usr/bin/env bash
# Auto-update hook for lrt-rocm plugin
# Runs async on session start — pulls latest from GitHub and reloads if changed.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
LOCK_FILE="/tmp/lrt-rocm-update.lock"
LOG_FILE="/tmp/lrt-rocm-update.log"

# Prevent concurrent updates
if [ -f "$LOCK_FILE" ]; then
    # Check if lock is stale (older than 5 minutes)
    if [ "$(find "$LOCK_FILE" -mmin +5 2>/dev/null)" ]; then
        rm -f "$LOCK_FILE"
    else
        exit 0
    fi
fi
trap 'rm -f "$LOCK_FILE"' EXIT
echo $$ > "$LOCK_FILE"

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') $1" >> "$LOG_FILE"
}

# Only update if plugin root is a git repo
if [ ! -d "${PLUGIN_ROOT}/.git" ]; then
    log "Not a git repo, skipping update"
    exit 0
fi

cd "$PLUGIN_ROOT"

# Fetch latest from remote
if ! git fetch origin --quiet 2>>"$LOG_FILE"; then
    log "Fetch failed, skipping update"
    exit 0
fi

# Check if there are new commits
LOCAL=$(git rev-parse HEAD 2>/dev/null)
REMOTE=$(git rev-parse origin/main 2>/dev/null || git rev-parse origin/master 2>/dev/null || echo "")

if [ -z "$REMOTE" ]; then
    log "Could not determine remote HEAD, skipping"
    exit 0
fi

if [ "$LOCAL" = "$REMOTE" ]; then
    log "Already up to date ($LOCAL)"
    exit 0
fi

# Pull updates (fast-forward only to avoid conflicts)
if git merge-base --is-ancestor "$LOCAL" "$REMOTE" 2>/dev/null; then
    log "Updating from $LOCAL to $REMOTE"
    if git pull --ff-only --quiet origin main 2>>"$LOG_FILE" || \
       git pull --ff-only --quiet origin master 2>>"$LOG_FILE"; then
        log "Updated successfully to $(git rev-parse --short HEAD)"
    else
        log "Pull failed, skipping"
        exit 0
    fi
else
    log "Local has diverged from remote, skipping auto-update"
    exit 0
fi

exit 0
